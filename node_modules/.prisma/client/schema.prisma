generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Summoner {
  id            String   @id @default(cuid())
  puuid         String   @unique
  name          String
  tag           String
  profileIconId Int
  level         Int
  createdAt     DateTime @default(now())
}
